SQL> -- ========== REPORT 5: JOB GRADE DISTRIBUTION ==========

SQL> SELECT jg.grade_level,
  2         COUNT(e.employee_id)  AS emp_count,
  3         MIN(e.salary)         AS min_sal,
  4         MAX(e.salary)         AS max_sal
  5  FROM   employees  e
  6  JOIN   job_grades jg ON e.salary BETWEEN jg.lowest_sal AND jg.highest_sal
  7  GROUP  BY jg.grade_level
  8  ORDER  BY jg.grade_level;


