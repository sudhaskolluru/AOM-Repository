SQL> -- ========== REPORT 2: TOP 10 HIGHEST PAID EMPLOYEES ==========

SQL> SELECT ROWNUM AS rank,
  2         e.employee_id,
  3         e.first_name || ' ' || e.last_name  AS full_name,
  4         d.department_name,
  5         j.job_title,
  6         e.salary,
  7         ROUND(e.salary * 12, 2)             AS annual_salary
  8  FROM   employees   e
  9  JOIN   departments d ON e.department_id = d.department_id
 10  JOIN   jobs         j ON e.job_id        = j.job_id
 11  ORDER  BY e.salary DESC
 12  FETCH  FIRST 10 ROWS ONLY;


