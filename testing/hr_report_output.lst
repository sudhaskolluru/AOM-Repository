SQL> -- ========== REPORT 1: EMPLOYEE SUMMARY BY DEPARTMENT ==========

SQL> SELECT d.department_name,
  2         COUNT(e.employee_id)     AS total_employees,
  3         ROUND(AVG(e.salary), 2)  AS avg_salary,
  4         MIN(e.salary)            AS min_salary,
  5         MAX(e.salary)            AS max_salary,
  6         SUM(e.salary)            AS total_salary_cost
  7  FROM   employees   e
  8  JOIN   departments d ON e.department_id = d.department_id
  9  GROUP  BY d.department_name
 10  ORDER  BY total_salary_cost DESC;


