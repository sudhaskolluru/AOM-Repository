SQL> -- ========== REPORT 4: EMPLOYEES WITH NO COMMISSION ==========

SQL> SELECT COUNT(*) AS employees_without_commission
  2  FROM   employees
  3  WHERE  commission_pct = 0 OR commission_pct IS NULL;


EMPLOYEES_WITHOUT_COMMISSION
