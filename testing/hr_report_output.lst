SQL> -- ========== REPORT 3: PAYROLL SUMMARY - MARCH 2026 ==========

SQL> SELECT d.department_name,
  2         COUNT(pl.employee_id)   AS employees_paid,
  3         SUM(pl.gross_pay)       AS total_gross,
  4         SUM(pl.deductions)      AS total_deductions,
  5         SUM(pl.net_pay)         AS total_net_pay
  6  FROM   payroll_ledger pl
  7  JOIN   employees      e  ON pl.employee_id  = e.employee_id
  8  JOIN   departments    d  ON e.department_id = d.department_id
  9  WHERE  pl.pay_month = 3 AND pl.pay_year = 2026
 10  GROUP  BY d.department_name
 11  ORDER  BY total_net_pay DESC;


